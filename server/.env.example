# --- ProjectFlow API ---
NODE_ENV=development
PORT=4000

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/projectflow

# Secret used to sign JWTs. CHANGE THIS in production.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Allowed origin for CORS + socket.io (your Next.js app)
CLIENT_ORIGIN=http://localhost:3000

# Directory for uploaded attachments (relative to server/)
UPLOAD_DIR=uploads
